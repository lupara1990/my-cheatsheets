</head>
<body>

    <nav>
        <div class="nav-inner">
            <a href="#" class="logo">RetroSprint</a>
            <div class="nav-links">
                <a href="#features">Features</a>
                <a href="#preview">Preview</a>
                <a href="#how-it-works">How It Works</a>
                <a href="#cta" class="btn-nav">Get Template</a>
