    <section id="how-it-works" class="how-it-works">
        <div class="container">
            <div class="section-label">
                <p class="overline">Get Started</p>
                <h2>Up and running in under a minute.</h2>
            </div>
            <div class="steps">
                <div class="step">
                    <span class="step-num">1</span>
                    <h3>Open the template</h3>
                    <p>Click the button below to open it in Miro.</p>
                </div>
                <div class="step-line"></div>
                <div class="step">
                    <span class="step-num">2</span>
                    <h3>Duplicate to your board</h3>
                    <p>Hit "Use template" to copy it into your workspace.</p>
                </div>
                <div class="step-line"></div>
                <div class="step">
                    <span class="step-num">3</span>
                    <h3>Run your retro</h3>
                    <p>Invite the team and start adding notes.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="cta" class="cta">
        <div class="container">
            <div class="cta-box">
                <h2>Ready to try it?</h2>
                <p>Free. No sign-up. Just open, duplicate, and run.</p>
                <a href="#" class="btn-primary btn-lg">
